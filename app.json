{
  "expo": {
    "name": "부산마켓",
    "slug": "dangn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/carrot.png",
    "scheme": "dangn",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/carrot.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/carrot.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.gk7428.dangn"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/carrot.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "06e14f16-aa0b-4896-82be-e3c014abf51d"
      }
    }
  }
}
